{
  "rewrites": [
    { "source": "/about", "destination": "/index.html" },
    { "source": "/forge", "destination": "/index.html" },
    { "source": "/lab", "destination": "/index.html" },
    { "source": "/threat", "destination": "/index.html" },
    { "source": "/activity", "destination": "/index.html" },
    { "source": "/stats", "destination": "/index.html" },
    { "source": "/toolkit", "destination": "/index.html" },
    { "source": "/ctf", "destination": "/index.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/contact", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/og-image.png",
      "headers": [
        { "key": "Content-Type", "value": "image/png" },
        { "key": "Cache-Control", "value": "public, max-age=86400, must-revalidate" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
